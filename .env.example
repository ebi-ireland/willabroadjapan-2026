# =====================
# .env.example
# このファイルはGitHubにコミットしてOK（値は空）
# 実際の値は .env に書く（GitHubには絶対上げない）
# =====================

# ── データベース ──────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=willabroadjapan

# ── セッション ────────────────────────────────────────────
SESSION_SECRET=
ADMIN_PASSWORD=

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Mapbox ───────────────────────────────────────────────
MAPBOX_TOKEN=

# ── Discord Webhook ───────────────────────────────────────
DISCORD_WEBHOOK=
DISCORD_CONTACT_WEBHOOK=
DISCORD_THREAD_NEW_WEBHOOK=
DISCORD_THREAD_REPORT_WEBHOOK=
DISCORD_EXPERIENCE_NEW_WEBHOOK=
DISCORD_EXPERIENCE_REPORT_WEBHOOK=
DISCORD_CONTACT_EDUCATION_WEBHOOK=
DISCORD_CONTACT_STUDENT_INTERNATIONAL_WEBHOOK=
DISCORD_CONTACT_SUPPORTER_WEBHOOK=

# ── その他 ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
BASE_URL=http://localhost:3000
DOMAIN=http://localhost:3000
NODE_ENV=development
